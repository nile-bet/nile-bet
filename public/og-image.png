<svg width="1200" height="630" xmlns="http://www.w3.org/2000/svg">
  <rect width="1200" height="630" fill="#1A1A2E"/>
  <rect x="0" y="0" width="1200" height="630" fill="url(#grad)"/>
  <defs>
