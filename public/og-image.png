  </defs>
  <text x="600" y="240" font-family="Georgia, serif" font-size="120" font-weight="900" fill="#C9A84C" text-anchor="middle" letter-spacing="20">NILE</text>
  <text x="600" y="320" font-family="Georgia, serif" font-size="48" fill="#C9A84C" text-anchor="middle" letter-spacing="10">BET</text>
  <line x1="300" y1="370" x2="900" y2="370" stroke="#C9A84C" stroke-width="2" opacity="0.5"/>
  <text x="600" y="430" font-family="Arial, sans-serif" font-size="32" fill="rgba(255,255,255,0.7)" text-anchor="middle">Flow into Wins</text>
  <text x="600" y="490" font-family="Arial, sans-serif" font-size="22" fill="rgba(255,255,255,0.4)" text-anchor="middle">Ethiopia's Premier Sports Betting Platform</text>
